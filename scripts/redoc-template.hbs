<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{{title}}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="{{title}}" />
    <link rel="icon" href="favicon.ico" sizes="any" />
    <style>
      @font-face {
        font-family: "Inter";
        src: url("inter-variable.woff2") format("woff2");
        font-style: normal;
        font-weight: 100 900;
        font-display: swap;
      }

      .navigation {
        display: flex;
        align-items: center;
        gap: 24px;
        padding: 12.5px 20px;
        border-bottom: 1px solid var(--border);
        background-color: var(--background);
      }

      .navigation-logo {
        display: block;
        height: 40px;
        width: auto;
      }

      .navigation-links {
        display: flex;
        align-items: center;
        gap: 24px;
      }

      .navigation-link {
        color: var(--foreground);
        font-size: 14px;
        font-weight: 400;
        line-height: 20px;
        text-decoration: none;
      }

      .navigation-link:hover,
      .navigation-link:focus-visible {
        color: var(--foreground);
        text-decoration: none;
      }

      :root {
        color-scheme: light;
        --background: #ffffff;
        --border: #e5e9f0; /* --color-grey-20 */
        --foreground: #343741; /* --color-ink */
        --muted: #516381; /* --color-subdued */
        --font-sans:
          "Inter", ui-sans-serif, system-ui, sans-serif, "Apple Color Emoji",
          "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
        --font-mono:
          ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
          "Liberation Mono", "Courier New", monospace;
      }

      body * {
        font-size: 14px;
        font-family: var(--font-sans) !important;
      }

      .menu-content {
        border-right: 1px solid var(--border) !important;
        background-color: var(--background) !important;
      }

      .scrollbar-container ul li label {
        background-color: transparent !important;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: var(--background);
        color: var(--foreground);
        font-family: var(--font-sans) !important;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      .reference-shell {
        flex: 1;
        min-height: 0;
      }
    </style>
    {{{redocHead}}}
  </head>
  <body>
    <nav class="navigation" aria-label="Primary">
      <a href="index.html" aria-label="Introduction">
        <img class="navigation-logo" src="elastic-logo.png" alt="Elastic" />
      </a>
      <div class="navigation-links">
        <a class="navigation-link" href="index.html">Introduction</a>
        <a class="navigation-link" href="dashboards.html#tag/Dashboards">Dashboards</a>
        <a class="navigation-link" href="visualizations.html#tag/Visualizations">Visualizations</a>
      </div>
    </nav>
    <div class="reference-shell">
      {{{redocHTML}}}
    </div>
  </body>
</html>