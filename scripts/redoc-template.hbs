<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{{title}}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Static OpenAPI reference for Dashboard Docs."
    />
    <link rel="icon" href="favicon.ico" sizes="any" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        color-scheme: light;
        --background: #ffffff;
        --border: #e5e9f0;     /* --color-grey-20 */
        --foreground: #343741; /* --color-ink */
        --muted: #516381;      /* --color-subdued */
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--background);
        color: var(--foreground);
        font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      a {
        color: inherit;
      }

      .reference-shell {
        padding-bottom: 2rem;
      }

      .site-shell {
        margin: 0 auto;
        width: 100%;
        max-width: 1400px;
        padding: 2rem 1.5rem 0;
      }

      .site-header {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 1.5rem;
      }

      .site-title {
        color: #71717a;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.24em;
        text-decoration: none;
        text-transform: uppercase;
      }

      .site-description {
        margin: 0.5rem 0 0;
        max-width: 42rem;
        color: var(--muted);
        font-size: 0.875rem;
        line-height: 1.5rem;
      }

      .site-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        font-size: 0.875rem;
        line-height: 1.25rem;
      }

      .site-nav a {
        font-weight: 500;
        text-decoration: none;
        transition: color 150ms ease;
      }

      .site-nav a:hover {
        color: var(--muted);
      }

      @media (min-width: 640px) {
        .site-shell {
          padding-left: 2.5rem;
          padding-right: 2.5rem;
        }

        .site-header {
          align-items: flex-end;
          flex-direction: row;
          gap: 1.5rem;
          justify-content: space-between;
        }

        .site-nav {
          justify-content: flex-end;
        }
      }

      @media (min-width: 1024px) {
        .site-shell {
          padding-left: 3rem;
          padding-right: 3rem;
        }
      }

      /* Override Redoc internals with Elastic design tokens */
      [data-role="search:input"],
      .redoc-wrap,
      .redoc-wrap *:not(code):not(pre):not(code *):not(pre *) {
        font-family: "Inter", ui-sans-serif, system-ui, sans-serif !important;
      }

      .redoc-wrap code,
      .redoc-wrap pre,
      .redoc-wrap code *,
      .redoc-wrap pre * {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace !important;
      }

      .redoc-wrap pre,
      .redoc-wrap [class*="CodeBlock"],
      .redoc-wrap [class*="code-block"] {
        background-color: #22272e !important;
        color: #d0d4da !important;
      }
    </style>
    {{{redocHead}}}
  </head>
  <body>
    <div class="reference-shell">
      {{{redocHTML}}}
    </div>
  </body>
</html>