{
  "name": "temp-dashboard-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:filtered-spec": "mkdir -p generated && node scripts/filter-openapi.mjs",
    "generate:spec-html": "NODE_OPTIONS=--max-old-space-size=8192 node scripts/generate-spec-html.mjs",
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 node scripts/dev.mjs",
    "dev:serve": "serve dist --listen 3000",
    "build": "npm run generate:spec-html",
    "prestart": "npm run build",
    "start": "serve dist --listen 3000",
    "lint": "eslint ."
  },
  "dependencies": {
    "@redocly/cli": "^2.28.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "chokidar": "^4.0.3",
    "@eslint/js": "^9.39.4",
    "eslint": "^9",
    "globals": "^16.4.0",
    "serve": "^14.2.0"
  }
}
